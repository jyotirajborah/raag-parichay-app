  "Diff - style": {
    "columns": [
      "Feature",
      "Hindustani Music (North India)",
      "Carnatic Music (South India)",
      "Western Music"
    ],
    "data": [
      {
        "Feature": "Core Principle",
        "Hindustani Music (North India)": "Melody (monophony), with an emphasis on expressive exploration of ragas.",
        "Carnatic Music (South India)": "Melody (monophony), more composition-based within a strict raga framework.",
        "Western Music": "Harmony and counterpoint (polyphony), focusing on chords and vertical alignment of notes."
      },
      {
        "Feature": "Notes/Pitch",
        "Hindustani Music (North India)": "Uses 12 semi-tones, but also incorporates subtle microtones (shruti) and fluid note transitions (meend).",
        "Carnatic Music (South India)": "Recognizes 22 microtones (shruti) per octave, used with highly codified ornamentation (gamaka).",
        "Western Music": "Uses 12 fixed, equally tempered semitones per octave (e.g., in a piano)."
      },
      {
        "Feature": "Structure",
        "Hindustani Music (North India)": "Emphasizes extended, free-flowing improvisation (alap, jod, jhala) that gradually builds in tempo and intensity.",
        "Carnatic Music (South India)": "Built around pre-composed pieces called kritis, where improvisation occurs within specific sections of the composition.",
        "Western Music": "Primarily based on written compositions following a fixed form (e.g., sonatas, symphonies, concertos). Strict adherence to the score is expected."
      },
      {
        "Feature": "Rhythm (Tala)",
        "Hindustani Music (North India)": "Features a variety of talas (rhythmic cycles) with scope for intricate improvisation.",
        "Carnatic Music (South India)": "Known for highly complex and mathematically precise rhythmic patterns and calculations.",
        "Western Music": "Typically uses simpler, repetitive meters (e.g., 4/4, 3/4 time signatures)."
      },
      {
        "Feature": "Origins/Influence",
        "Hindustani Music (North India)": "Evolved from ancient Vedic traditions with significant Persian and Mughal influences.",
        "Carnatic Music (South India)": "Retained a more indigenous, ancient Hindu musical tradition with less external influence.",
        "Western Music": "Roots in European classical traditions, with secular origins and a focus on structure and precision."
      },
      {
        "Feature": "Key Instruments",
        "Hindustani Music (North India)": "Sitar, sarod, tabla, harmonium, bansuri (flute), sarangi.",
        "Carnatic Music (South India)": "Veena, mridangam, violin (played seated), flute.",
        "Western Music": "Piano, violin, cello, trumpet, guitar, drums, orchestra."
      },
