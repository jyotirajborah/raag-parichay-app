    "data": [
      {
        "Tier": "Tier 1: UGC-Accredited Universities",
        "Main Purpose": "To provide formal academic education combining theory and practice, grant officially recognized degrees, and prepare students for academic, research, and government cultural careers.",
        "Feature": "Accreditation",
        "Description": "These are full-fledged universities recognized by the University Grants Commission (UGC), a statutory body of the Indian government. Their degrees (B.A., M.A., B.P.A., M.P.A., Ph.D.) are officially sanctioned for employment in government and education sectors across India."
      },
      {
        "Tier": null,
        "Main Purpose": null,
        "Feature": "Education Style",
        "Description": "They offer comprehensive, formal academic programs that combine practical training with theoretical knowledge, research, history, aesthetics, and pedagogy. The curriculum is structured and often interdisciplinary."
      },
      {
        "Tier": null,
        "Main Purpose": null,
        "Feature": "Career Path",
        "Description": "A degree from a Tier 1 institution provides the highest level of official qualification for academic careers, such as university professors, researchers, and government cultural officers. It also opens doors to general employment opportunities requiring a formal university degree."
      },
      {
        "Tier": null,
        "Main Purpose": null,
        "Feature": "Campus Life",
        "Description": "These are traditional university campuses with infrastructure, libraries, research facilities, and a diverse student body engaging in various academic and extracurricular activities."
      },
      {
        "Tier": "Tier 2: Prominent Examination Boards",
        "Main Purpose": "To offer performance-focused, practical training in music and arts through diplomas/certificates that enable teaching, professional performance, and local recognition within the arts community.",
        "Feature": "Accreditation",
        "Description": "These are private, non-profit organizations or cultural bodies. They do not grant university degrees directly but offer diplomas and certificates that are widely recognized and valued within the music and arts community. In many cases, their senior diplomas (like Sangeet Prabhakar) are considered equivalent to a B.A. or M.A. degree for the purpose of teaching in affiliated schools or certain government jobs."
      },
      {
        "Tier": null,
        "Main Purpose": null,
        "Feature": "Education Style",
        "Description": "The primary focus is often practical, performance-based training and a rigorous examination system with a vast network of affiliated local teaching centers. The learning experience is typically more practical and less theoretical than a university degree program."
      },
      {
        "Tier": null,
        "Main Purpose": null,
        "Feature": "Career Path",
        "Description": "Graduates often become music or dance teachers at private institutions, open their own local classes, or pursue professional performance careers. The \"equivalency\" of their diplomas to formal degrees can vary depending on the specific employer or state education board's rules."
      },
      {
        "Tier": null,
        "Main Purpose": null,
        "Feature": "Structure",
        "Description": "They operate through a decentralized network of many smaller, affiliated centers, rather than a single, large university campus."
      },
      {
        "Tier": "Tier 3: Specialized & International Academies/Boards",
        "Main Purpose": "To develop highly specialized skills in specific instruments, genres, or contemporary arts through internationally recognized graded examinations, mainly for professional performers and global opportunities.",
        "Feature": "Accreditation",
        "Description": "These include international bodies (like Trinity or ABRSM) or local specialized academies. Their primary focus is on standardized graded examinations that are globally recognized within the music industry and sometimes for higher education applications abroad (e.g., UCAS points for UK universities)."
      },
      {
        "Tier": null,
        "Main Purpose": null,
        "Feature": "Education Style",
        "Description": "They provide a structured grading system focused purely on musical or artistic skill development and performance repertoire within specific genres (often Western music, pop, or contemporary styles). The focus is highly practical and skill-based."
      }
    ]
